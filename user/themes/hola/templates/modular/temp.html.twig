    <div class="usecase-content" style="background-image: url(/user/pages/01.home/04._usecase/use-cases-1-new.jpg); background-size: cover;opacity: 1 ">
        <div class="overlay" style="opacity:{{ page.header.bannerOpacity }};"></div>
        <div class="shadow-overlay"></div>

        {% if page.header.bullet %}
            <ul class="usecase-bullet">
                {% for bullet in page.header.bullet %}
                    <li>
                        <i class="{{ bullet.icon }}" aria-hidden="true"></i>
                    </li>
                {% endfor %}
            </ul> <!-- end usecase-icon -->
        {% endif %}

        <div class="row usecase-content__main">

            <h3>{{ page.header.subtitle }}</h3>

            <h1>
                {{ page.title }}
            </h1>

            <p>{{ content }}</p>

            <div class="usecase-content__buttons">
            
                {{ page.media['night_track.ogg'].preload('metadata')|raw }}
                {% if page.header.button1Text %}
                    <a href="{{ page.header.button1Link }}" class="smoothscroll btn btn--stroke">
                        {{ page.header.button1Text }}
                    </a>
                {% endif %}
                {% if page.header.button2Text %}
                    <a href="{{ page.header.button2Link }}" class="smoothscroll btn btn--stroke">
                        {{ page.header.button2Text }}
                    </a>
                {% endif %}
            </div>

            <div class="usecase-content__scroll">
                <a href="{{ page.header.button3Link }}" class="scroll-link smoothscroll">
                    <span>{{ page.header.button3Text }}</span>
                </a>
            </div>

        </div>
    </div> <!-- end usecase-content -->
